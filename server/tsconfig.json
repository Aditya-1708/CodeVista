{
  "compilerOptions": {
    /* File Structure */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Language & Module Settings */
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* Type Support */
    "types": ["node"],

    /* Output Settings */
    "sourceMap": true,
    "declaration": true,

    /* Strictness */
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,

    /* Compatibility */
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
