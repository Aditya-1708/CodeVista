generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String?
  email     String   @unique
  password  String?
  createdAt DateTime @default(now())
  codeBooks CodeBook[]
}

enum Language {
  JAVA
  JAVASCRIPT
  PYTHON
  C
  CPP
  SQL
}

model CodeBook {
  id        Int      @id @default(autoincrement())

  name      String   @default("Untitled Book")

  code      String   @db.Text

  stdout    String?  @db.Text
  stderr    String?  @db.Text

  language  Language

  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}